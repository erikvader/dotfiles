# General settings not specific to a particular user or host.
[pull]
    ff = only
[push]
    autoSetupRemote = true
[fetch]
    recurseSubmodules = on-demand
    parallel = 0
[submodule]
    fetchJobs = 0
[merge]
    conflictstyle = zdiff3
[rerere]
    enabled = true
[init]
    defaultBranch = master
[core]
    autocrlf = input
    quotepath = off
[diff]
    algorithm = histogram
    colorMoved = default
    renames = copies
    mnemonicPrefix = true
[pretty]
    oneline2 = format:%C(yellow)%h%Creset -%C(auto)%d%Creset %s %Cgreen(%ad) %C(bold blue)<%an>%Creset
[log]
    date = iso
